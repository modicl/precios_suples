generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model categorias {
  id_categoria     Int             @id @default(autoincrement())
  nombre_categoria String          @unique(map: "uq_nombre_categoria") @db.VarChar(255)
  subcategorias    subcategorias[]
}

model historia_precios {
  id_historia_precio Int             @id @default(autoincrement())
  id_producto_tienda Int
  precio             Int
  fecha_precio       DateTime?       @default(dbgenerated("CURRENT_DATE")) @db.Timestamp(6)
  producto_tienda    producto_tienda @relation(fields: [id_producto_tienda], references: [id_producto_tienda], onDelete: NoAction, onUpdate: NoAction, map: "fk_producto_tienda")

  @@index([id_producto_tienda, fecha_precio(sort: Desc), precio], map: "idx_historia_precios_covering")
}

model marcas {
  id_marca     Int         @id @default(autoincrement())
  nombre_marca String      @unique(map: "uq_nombre_marca") @db.VarChar(255)
  productos    productos[]
}

model producto_tienda {
  id_producto_tienda Int                @id @default(autoincrement())
  id_producto        Int
  id_tienda          Int
  url_link           String?
  descripcion        String?
  historia_precios   historia_precios[]
  productos          productos          @relation(fields: [id_producto], references: [id_producto], onDelete: NoAction, onUpdate: NoAction, map: "fk_producto")
  tiendas            tiendas            @relation(fields: [id_tienda], references: [id_tienda], onDelete: NoAction, onUpdate: NoAction, map: "fk_tienda")

  @@unique([id_producto, id_tienda], map: "uq_producto_tienda")
}

model productos {
  id_producto      Int               @id @default(autoincrement())
  nombre_producto  String            @db.VarChar(255)
  url_imagen       String?           @db.VarChar(500)
  url_thumb_imagen String?           @db.VarChar(500)
  descripcion      String?
  id_marca         Int?
  id_subcategoria  Int?
  is_vegan         Boolean?          @default(false)
  is_women         Boolean?          @default(false)
  clickAnalytics   click_analytics[]
  producto_tienda  producto_tienda[]
  marcas           marcas?           @relation(fields: [id_marca], references: [id_marca], onDelete: NoAction, onUpdate: NoAction, map: "fk_marca")
  subcategorias    subcategorias?    @relation(fields: [id_subcategoria], references: [id_subcategoria], onDelete: NoAction, onUpdate: NoAction, map: "fk_subcategoria")

  @@unique([nombre_producto, id_marca, id_subcategoria], map: "uq_nombre_producto")
}

model click_analytics {
  id_click_analytics Int       @id @default(autoincrement())
  id_producto        Int
  fecha_click        DateTime  @default(now())
  producto           productos @relation(fields: [id_producto], references: [id_producto], onDelete: NoAction, onUpdate: NoAction, map: "fk_producto")
}

model search_analytics {
  id_search_analytics Int      @id @default(autoincrement())
  keyword             String
  fecha_search        DateTime @default(now())
}

model subcategorias {
  id_subcategoria     Int         @id @default(autoincrement())
  nombre_subcategoria String      @db.VarChar(255)
  id_categoria        Int
  productos           productos[]
  categorias          categorias  @relation(fields: [id_categoria], references: [id_categoria], onDelete: NoAction, onUpdate: NoAction, map: "fk_categoria")

  @@unique([nombre_subcategoria, id_categoria], map: "uq_nombre_subcategoria")
}

model tiendas {
  id_tienda       Int               @id @default(autoincrement())
  nombre_tienda   String            @unique(map: "uq_nombre_tioenda") @db.VarChar(255)
  url_tienda      String?           @db.VarChar(255)
  producto_tienda producto_tienda[]
}

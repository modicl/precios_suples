# =============================================================================
# .dockerignore — ComparaFit Scraper
# Excluye archivos innecesarios del contexto de build de Docker.
# Reducir el contexto acelera el build y evita secretos en la imagen.
# =============================================================================

# ── Secretos ─────────────────────────────────────────────────────────────────
.env
*.pem
*.key

# ── Entornos virtuales ────────────────────────────────────────────────────────
venv/
env/
.venv/

# ── Python bytecode ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Datos de runtime (generados durante la ejecución, no en build) ────────────
raw_data/
logs/
*.log
*.db
local_processing_testing/data/

# ── Archivos legacy / desarrollo ─────────────────────────────────────────────
old/
*.bat
run_pipeline.bat
run_scrapers.bat

# ── Assets e imágenes de debugging ───────────────────────────────────────────
assets/
img_debugging/
aws/
bd/

# ── IDEs y herramientas de desarrollo ────────────────────────────────────────
.vscode/
.idea/
.claude/
.agents/
.agent/
.opencode/

# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.gitignore

# ── Documentación (no necesaria en runtime) ───────────────────────────────────
README.md
CHANGELOG.md
skills-lock.json

# ── Miscelánea ────────────────────────────────────────────────────────────────
# NOTA: NO excluimos *.csv globalmente porque diccionario_categorias.csv
# (raíz del proyecto) es necesario en runtime. Solo excluimos archivos puntuales.
suples.db
